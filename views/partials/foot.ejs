</main>

<!-- Scan progress toast (global, all pages) -->
<div id="scan-toast" class="fixed bottom-4 right-4 bg-gray-800 border border-gray-700 rounded-lg p-4 shadow-xl z-50 hidden opacity-0 transition-opacity duration-300 w-80">
  <div class="flex items-start gap-3">
    <div class="mt-0.5 flex-shrink-0">
      <svg class="w-5 h-5 text-blue-400 animate-spin" id="scan-toast-spinner" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
    </div>
    <div class="flex-1 min-w-0">
      <p id="scan-toast-phase" class="text-sm font-medium">Scanning...</p>
      <p id="scan-toast-detail" class="text-xs text-gray-400 mt-0.5 truncate"></p>
      <div class="mt-2 w-full h-1.5 bg-gray-700 rounded-full overflow-hidden">
        <div id="scan-toast-bar" class="h-full bg-blue-500 rounded-full transition-all duration-300" style="width: 0%"></div>
      </div>
    </div>
    <button id="scan-toast-close" class="text-gray-500 hover:text-gray-300 flex-shrink-0" title="Dismiss">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
</div>
<script src="/js/scan-toast.js"></script>

</body>
</html>
