<div class="sm:col-span-2">
  <label class="block text-gray-500 mb-1"><%= tagLabel %></label>
  <div id="<%= tagType %>-tags" class="flex flex-wrap gap-1.5 mb-2">
    <% tagItems.forEach(function(item) { %>
    <span class="inline-flex items-center gap-1 bg-gray-700 text-gray-200 px-2 py-1 rounded-full text-xs" data-tag-id="<%= item.id %>">
      <%= item.name %>
      <button type="button" onclick="removeVideoTag('<%= tagType %>', <%= item.id %>, this)" class="text-gray-500 hover:text-red-400 transition-colors">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </span>
    <% }) %>
  </div>
  <div class="relative flex gap-1">
    <div class="flex-1 relative">
      <input type="text" id="<%= tagType %>-add-input" placeholder="<%= tagPlaceholder %>" autocomplete="off"
        class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500"
        data-autocomplete="<%= tagType %>">
      <div id="<%= tagType %>-dropdown" class="hidden absolute left-0 right-0 top-full mt-1 bg-gray-700 border border-gray-600 rounded shadow-lg max-h-40 overflow-y-auto z-20"></div>
    </div>
    <button type="button" onclick="addVideoTag('<%= tagType %>', '<%= tagType %>-add-input', '<%= tagType %>-tags')" class="bg-gray-600 hover:bg-gray-500 px-2 py-1.5 rounded text-sm transition-colors">Add</button>
  </div>
</div>
