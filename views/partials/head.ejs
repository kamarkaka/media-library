<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title ? title + ' — Media Library' : 'Media Library' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwindcss.config = { darkMode: 'class' }</script>
  <link rel="stylesheet" href="/css/styles.css">
  <script src="/js/utils.js"></script>
</head>
<body class="dark bg-gray-900 text-gray-100 min-h-screen flex flex-col">
<% if (authenticated) { %>
<nav class="bg-gray-800 border-b border-gray-700 px-6 py-3 flex items-center justify-between flex-shrink-0">
  <a href="/" class="text-xl font-bold text-white hover:text-blue-400 transition-colors">Media Library</a>
  <div class="flex items-center gap-4">
    <a href="/" class="text-gray-300 hover:text-white text-sm">Library</a>
    <a href="/settings" class="text-gray-300 hover:text-white text-sm">Settings</a>
    <form action="/logout" method="POST" class="inline">
      <button type="submit" class="text-gray-500 hover:text-white text-sm">Logout</button>
    </form>
  </div>
</nav>
<% } %>
<main class="flex-1 flex flex-col">
