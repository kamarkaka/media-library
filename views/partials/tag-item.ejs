<span class="tag-item inline-flex items-center gap-1 bg-gray-700 text-gray-200 px-3 py-1.5 rounded-full text-sm" data-tag-id="<%= tag.id %>">
  <a href="/?<%= tagType === 'genres' ? 'genre' : 'cast' %>=<%= encodeURIComponent(tag.name) %>" class="hover:text-white transition-colors"><%= tag.name %><% if (tag.alias) { %> <span class="text-gray-400">(<%= tag.alias %>)</span><% } %></a>
  <span class="text-xs text-gray-500"><%= tag.count %></span>
  <button onclick="copyTagName(this)" class="text-gray-500 hover:text-green-400 transition-colors" title="Copy name">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
  </button>
  <% if (tagType === 'genres') { %>
  <button onclick="editAlias(<%= tag.id %>, this)" class="text-gray-500 hover:text-blue-400 transition-colors" title="Edit alias">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
  </button>
  <% } %>
  <button onclick="deleteTag(<%= tag.id %>)" class="text-gray-500 hover:text-red-400 transition-colors" title="Remove">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
</span>
