<%- include('partials/head') %>
<div class="max-w-3xl mx-auto p-6">
  <h1 class="text-2xl font-bold mb-6"><%= title %></h1>

  <section class="bg-gray-800 rounded-lg p-6">
    <form id="add-tag-form" class="flex gap-2 mb-4">
      <input type="text" id="tag-input" placeholder="Add new <%= tagType === 'genres' ? 'genre' : 'cast member' %>..." required
        class="flex-1 bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500">
      <button type="submit" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded text-sm transition-colors">Add</button>
    </form>

    <% if (typeof groups !== 'undefined' && groups) { %>
    <% groups.forEach(function(group, gi) { %>
    <div class="<%= gi > 0 ? 'mt-6' : '' %>">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3"><%= group.label %> <span class="text-gray-600">(<%= group.tags.length %>)</span></h2>
      <div<% if (group.isAddTarget) { %> id="tag-list"<% } %> class="flex flex-wrap gap-2">
        <% group.tags.forEach(function(tag) { %>
        <%- include('partials/tag-item', { tag: tag, tagType: tagType }) %>
        <% }) %>
      </div>
      <% if (group.tags.length === 0) { %>
      <p class="text-gray-500 text-sm">None.</p>
      <% } %>
    </div>
    <% }) %>
    <% } else { %>
    <div id="tag-list" class="flex flex-wrap gap-2">
      <% tags.forEach(function(tag) { %>
      <%- include('partials/tag-item', { tag: tag, tagType: tagType }) %>
      <% }) %>
    </div>

    <% if (tags.length === 0) { %>
    <p id="no-tags-msg" class="text-gray-500 text-sm">No <%= tagType === 'genres' ? 'genres' : 'cast members' %> yet.</p>
    <% } %>
    <% } %>
  </section>
</div>

<script>
(function () {
  var tagType = '<%= tagType %>';
  var form = document.getElementById('add-tag-form');
  var input = document.getElementById('tag-input');
  var list = document.getElementById('tag-list');
  var noMsg = document.getElementById('no-tags-msg');

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var name = input.value.trim();
    if (!name) return;

    fetch('/api/' + tagType, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: name }),
    })
      .then(function (res) {
        if (!res.ok) return res.json().then(function (d) { throw new Error(d.error); });
        return res.json();
      })
      .then(function (tag) {
        var span = document.createElement('span');
        span.className = 'tag-item inline-flex items-center gap-1 bg-gray-700 text-gray-200 px-3 py-1.5 rounded-full text-sm';
        span.dataset.tagId = tag.id;
        var filterParam = tagType === 'genres' ? 'genre' : 'cast';
        span.innerHTML = '<a href="/?' + filterParam + '=' + encodeURIComponent(tag.name) + '" class="hover:text-white transition-colors">' + escapeHtml(tag.name) + '</a>' +
          '<button onclick="deleteTag(' + tag.id + ')" class="text-gray-500 hover:text-red-400 ml-1 transition-colors" title="Remove">' +
          '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>' +
          '</button>';
        list.appendChild(span);
        if (noMsg) noMsg.remove();
        input.value = '';
      })
      .catch(function (err) { alert(err.message); });
  });

  window.copyTagName = function (btn) {
    var tag = btn.closest('[data-tag-id]');
    var link = tag.querySelector('a');
    var name = link.childNodes[0].textContent.trim();
    navigator.clipboard.writeText(name).then(function () {
      var original = btn.innerHTML;
      btn.innerHTML = '<svg class="w-3.5 h-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
      setTimeout(function () { btn.innerHTML = original; }, 1000);
    });
  };

  window.editAlias = function (id, btn) {
    var tag = btn.closest('[data-tag-id]');
    var link = tag.querySelector('a');
    var currentAlias = '';
    var aliasSpan = link.querySelector('.text-gray-400');
    if (aliasSpan) currentAlias = aliasSpan.textContent.replace(/[()]/g, '').trim();
    var newAlias = prompt('Enter alias for this genre (leave empty to remove):', currentAlias);
    if (newAlias === null) return;

    fetch('/api/' + tagType + '/' + id, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ alias: newAlias }),
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (aliasSpan) aliasSpan.remove();
        if (data.alias) {
          var span = document.createElement('span');
          span.className = 'text-gray-400';
          span.textContent = ' (' + data.alias + ')';
          link.appendChild(span);
        }
      })
      .catch(function (err) { alert('Failed: ' + err.message); });
  };

  window.deleteTag = function (id) {
    if (!confirm('Remove this ' + (tagType === 'genres' ? 'genre' : 'cast member') + '?')) return;
    fetch('/api/' + tagType + '/' + id, { method: 'DELETE' })
      .then(function (res) {
        if (res.ok) {
          var el = document.querySelector('[data-tag-id="' + id + '"]');
          if (el) el.remove();
        }
      })
      .catch(function (err) { alert('Failed: ' + err.message); });
  };
})();
</script>
<%- include('partials/foot') %>
