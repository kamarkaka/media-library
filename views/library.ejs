<%- include('partials/head') %>
<div class="flex flex-1 overflow-hidden">
  <div class="flex-1 overflow-y-auto p-6" id="library-content">
    <!-- Search -->
    <div class="flex items-center gap-3 mb-3">
      <form method="GET" action="/" class="flex-1 flex gap-2" id="search-form">
        <div class="flex-1 relative">
          <input type="text" name="q" id="search-input" value="<%= currentFilters.q || '' %>" placeholder="Search videos..." autocomplete="off"
            class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-blue-500">
          <div id="search-dropdown" class="hidden absolute left-0 right-0 top-full mt-1 bg-gray-800 border border-gray-700 rounded shadow-lg max-h-80 overflow-y-auto z-30"></div>
        </div>
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded text-sm">Search</button>
        <% if (currentFilters.q) { %>
        <a href="/" class="bg-gray-700 hover:bg-gray-600 px-3 py-2 rounded text-sm text-gray-300 transition-colors">Clear</a>
        <% } %>
      </form>
    </div>

    <!-- Filter Pills -->
    <div id="filter-pills" class="mb-4"
         data-current='<%- JSON.stringify({ genre: currentFilters.genre || [], cast: currentFilters.cast || [], director: currentFilters.director || [], maker: currentFilters.maker || [], label: currentFilters.label || [], match: currentFilters.match || '' }) %>'>
    </div>

    <% if (recentPlayback && recentPlayback.position > 0) { %>
    <a href="/player/<%= recentPlayback.id %>"
       class="flex items-center gap-3 bg-blue-900/20 border border-blue-800/50 rounded-lg px-4 py-3 mb-5 hover:bg-blue-900/30 transition-colors">
      <svg class="w-5 h-5 text-blue-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z"/>
      </svg>
      <span class="text-sm"><span class="text-blue-400">Resume:</span> <%= recentPlayback.filename %></span>
    </a>
    <% } %>

    <!-- Video Grid -->
    <% const isCompact = currentFilters.match === 'unmatched'; %>
    <div class="grid gap-2 <%= isCompact ? 'grid-cols-1 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-8 2xl:grid-cols-10' : 'grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 2xl:grid-cols-8 gap-3' %>" id="video-grid" data-compact="<%= isCompact ? '1' : '' %>">
      <% videos.forEach(function(video) { %>
        <% if (isCompact) { %>
        <a href="/player/<%= video.id %>" class="group bg-gray-800 rounded px-2 py-1.5 hover:bg-gray-700 transition-colors flex items-center gap-1.5 min-w-0">
          <svg class="w-3.5 h-3.5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-xs text-gray-300 truncate"><%= video.filename %></span>
        </a>
        <% } else { %>
        <%- include('partials/video-card', { video: video, playback: playbackMap.get(video.id) }) %>
        <% } %>
      <% }) %>
    </div>

    <% if (pagination.totalPages > 1) { %>
    <%
      function pageUrl(p) {
        var params = new URLSearchParams();
        if (currentFilters.q) params.set('q', currentFilters.q);
        if (currentFilters.genre && currentFilters.genre.length) params.set('genre', currentFilters.genre.join(','));
        if (currentFilters.cast && currentFilters.cast.length) params.set('cast', currentFilters.cast.join(','));
        if (currentFilters.director && currentFilters.director.length) params.set('director', currentFilters.director.join(','));
        if (currentFilters.maker && currentFilters.maker.length) params.set('maker', currentFilters.maker.join(','));
        if (currentFilters.label && currentFilters.label.length) params.set('label', currentFilters.label.join(','));
        if (currentFilters.match) params.set('match', currentFilters.match);
        if (currentFilters.sort && currentFilters.sort !== 'release_date') params.set('sort', currentFilters.sort);
        if (p > 1) params.set('page', String(p));
        var qs = params.toString();
        return '/' + (qs ? '?' + qs : '');
      }
    %>
    <div class="flex items-center justify-center gap-2 mt-6 mb-2">
      <% if (pagination.page > 1) { %>
      <a href="<%= pageUrl(pagination.page - 1) %>" class="px-3 py-1.5 rounded text-sm bg-gray-700 text-gray-300 hover:bg-gray-600 transition-colors">Prev</a>
      <% } %>

      <% var startPage = Math.max(1, pagination.page - 2); %>
      <% var endPage = Math.min(pagination.totalPages, startPage + 4); %>
      <% startPage = Math.max(1, endPage - 4); %>

      <% if (startPage > 1) { %>
      <a href="<%= pageUrl(1) %>" class="px-3 py-1.5 rounded text-sm bg-gray-700 text-gray-300 hover:bg-gray-600 transition-colors">1</a>
      <% if (startPage > 2) { %><span class="text-gray-500 text-sm px-1">...</span><% } %>
      <% } %>

      <% for (var p = startPage; p <= endPage; p++) { %>
      <a href="<%= pageUrl(p) %>" class="px-3 py-1.5 rounded text-sm transition-colors <%= p === pagination.page ? 'bg-blue-600 text-white' : 'bg-gray-700 text-gray-300 hover:bg-gray-600' %>"><%= p %></a>
      <% } %>

      <% if (endPage < pagination.totalPages) { %>
      <% if (endPage < pagination.totalPages - 1) { %><span class="text-gray-500 text-sm px-1">...</span><% } %>
      <a href="<%= pageUrl(pagination.totalPages) %>" class="px-3 py-1.5 rounded text-sm bg-gray-700 text-gray-300 hover:bg-gray-600 transition-colors"><%= pagination.totalPages %></a>
      <% } %>

      <% if (pagination.page < pagination.totalPages) { %>
      <a href="<%= pageUrl(pagination.page + 1) %>" class="px-3 py-1.5 rounded text-sm bg-gray-700 text-gray-300 hover:bg-gray-600 transition-colors">Next</a>
      <% } %>

      <span class="text-xs text-gray-500 ml-2"><%= pagination.total %> videos</span>
    </div>
    <% } %>

    <% if (videos.length === 0) { %>
    <div class="text-center text-gray-500 py-20">
      <svg class="w-16 h-16 mx-auto mb-4 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
              d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/>
      </svg>
      <p class="text-lg">No videos found</p>
      <% if (!currentFilters.q && !currentFilters.genre && !currentFilters.director) { %>
      <p class="mt-2 text-sm">Add video paths in <a href="/settings" class="text-blue-400 hover:underline">Settings</a> and scan your library.</p>
      <% } %>
    </div>
    <% } %>
  </div>
</div>
<script src="/js/library.js"></script>
<%- include('partials/foot') %>
