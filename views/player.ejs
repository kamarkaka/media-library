<%- include('partials/head') %>
<div class="flex flex-col flex-1">
  <!-- Video Player -->
  <div class="flex-1 bg-black flex items-center justify-center relative min-h-0">
    <video id="video-player" class="max-h-full max-w-full" controls autoplay
           data-video-id="<%= video.id %>"
           data-resume-position="<%= playback ? playback.position : 0 %>">
      <source src="/api/videos/<%= video.id %>/stream" type="video/mp4">
      Your browser does not support the video tag.
    </video>

    <% if (prevVideo) { %>
    <a href="/player/<%= prevVideo.id %>"
       class="absolute left-2 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/70 p-2.5 rounded-full transition-colors"
       title="Previous: <%= prevVideo.filename %>">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    </a>
    <% } %>

    <% if (nextVideo) { %>
    <a href="/player/<%= nextVideo.id %>"
       class="absolute right-2 top-1/2 -translate-y-1/2 bg-black/40 hover:bg-black/70 p-2.5 rounded-full transition-colors"
       title="Next: <%= nextVideo.filename %>">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
    <% } %>
  </div>

  <!-- Info Bar -->
  <div class="bg-gray-800 border-t border-gray-700 px-6 py-3 flex-shrink-0">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0 flex-1">
        <h1 class="text-base font-semibold truncate" title="<%= video.filename %>"><%= video.filename %></h1>
        <%
          const hasMetadata = video.director || video.maker || video.label ||
                              video.release_date || video.length || genres.length || cast.length;
        %>
        <% if (hasMetadata) { %>
        <div class="mt-1.5 text-sm text-gray-400 flex flex-wrap gap-x-4 gap-y-0.5">
          <% if (video.release_date) { %><span>Release: <%= video.release_date %></span><% } %>
          <% if (video.director) { %><span>Director: <%= video.director %></span><% } %>
          <% if (video.maker) { %><span>Maker: <%= video.maker %></span><% } %>
          <% if (video.label) { %><span>Label: <%= video.label %></span><% } %>
          <% if (video.length) { %><span>Duration: <%= Math.floor(video.length / 60) %>m <%= video.length % 60 %>s</span><% } %>
          <% if (genres.length) { %><span>Genres: <%= genres.map(function(g) { return g.name; }).join(', ') %></span><% } %>
          <% if (cast.length) { %><span>Cast: <%= cast.map(function(c) { return c.name; }).join(', ') %></span><% } %>
        </div>
        <% } %>
      </div>
      <div class="flex gap-2 flex-shrink-0">
        <% if (prevVideo) { %>
        <a href="/player/<%= prevVideo.id %>" class="bg-gray-700 hover:bg-gray-600 px-3 py-1 rounded text-sm transition-colors">Prev</a>
        <% } %>
        <% if (nextVideo) { %>
        <a href="/player/<%= nextVideo.id %>" class="bg-gray-700 hover:bg-gray-600 px-3 py-1 rounded text-sm transition-colors">Next</a>
        <% } %>
        <a href="/" class="bg-gray-700 hover:bg-gray-600 px-3 py-1 rounded text-sm transition-colors">Library</a>
      </div>
    </div>
  </div>
</div>
<script src="/js/player.js"></script>
<%- include('partials/foot') %>
