<%- include('partials/head') %>
<div class="flex flex-col flex-1">
  <!-- Video Player -->
  <div id="video-container" class="bg-black flex items-center justify-center relative">
    <video id="video-player" class="w-full" style="max-width: 960px" controls
           data-video-id="<%= video.id %>"
           data-resume-position="<%= playback ? playback.position : 0 %>">
      <source src="/api/videos/<%= video.id %>/stream" type="video/mp4">
      Your browser does not support the video tag.
    </video>

    <% if (prevVideo) { %>
    <a href="/player/<%= prevVideo.id %>" class="video-nav video-nav-prev" title="Previous: <%= prevVideo.filename %>">
      <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
        <path d="M8.445 14.832A1 1 0 0010 14v-2.798l5.445 3.63A1 1 0 0017 14V6a1 1 0 00-1.555-.832L10 8.798V6a1 1 0 00-1.555-.832l-6 4a1 1 0 000 1.664l6 4z"/>
      </svg>
    </a>
    <% } %>

    <% if (nextVideo) { %>
    <a href="/player/<%= nextVideo.id %>" class="video-nav video-nav-next" title="Next: <%= nextVideo.filename %>">
      <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
        <path d="M4.555 5.168A1 1 0 003 6v8a1 1 0 001.555.832L10 11.202V14a1 1 0 001.555.832l6-4a1 1 0 000-1.664l-6-4A1 1 0 0010 6v2.798L4.555 5.168z"/>
      </svg>
    </a>
    <% } %>
  </div>

  <!-- Video Details -->
  <div class="bg-gray-800 border-t border-gray-700/50 px-6 py-4 flex-shrink-0">
    <% const displayTitle = video.name || video.filename; %>
    <h1 class="text-base font-semibold break-words mb-4"><%= displayTitle %></h1>

    <%
      const GB = 1024 * 1024 * 1024;
      const MB = 1024 * 1024;
    %>
    <button type="button" id="metadata-toggle" class="flex items-center gap-1 text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 hover:text-gray-300 transition-colors">
      <svg id="metadata-chevron" class="w-3.5 h-3.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      Metadata
    </button>
    <div id="metadata-content" class="text-sm text-gray-400 grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-1 mb-4" style="display: none">
      <div class="flex justify-between"><span class="text-gray-500">Filename</span><span class="text-gray-300 truncate ml-2"><%= video.filename %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Duration</span><span class="text-gray-300"><%= video.length != null ? Math.floor(video.length / 60) + 'm ' + (video.length % 60) + 's' : '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Resolution</span><span class="text-gray-300"><%= video.width && video.height ? video.width + ' × ' + video.height : '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Video Codec</span><span class="text-gray-300"><%= video.video_codec || '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Audio Codec</span><span class="text-gray-300"><%= video.audio_codec || '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Framerate</span><span class="text-gray-300"><%= video.framerate != null ? video.framerate + ' fps' : '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Bitrate</span><span class="text-gray-300"><%= video.bitrate ? (video.bitrate / 1000).toFixed(0) + ' kbps' : '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">File Size</span><span class="text-gray-300"><%= video.file_size ? (video.file_size >= GB ? (video.file_size / GB).toFixed(2) + ' GB' : (video.file_size / MB).toFixed(1) + ' MB') : '—' %></span></div>
    </div>

    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 mt-4 pt-4 border-t border-gray-700/50">Details</h2>
    <form id="video-meta-form" data-video-id="<%= video.id %>">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-3 text-sm">
        <div>
          <label class="block text-gray-500 mb-1">Code</label>
          <input type="text" name="code" value="<%= video.code || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Name</label>
          <input type="text" name="name" value="<%= video.name || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Release Date</label>
          <input type="date" name="release_date" value="<%= video.release_date || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Director</label>
          <input type="text" name="director" value="<%= video.director || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Maker</label>
          <input type="text" name="maker" value="<%= video.maker || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Label</label>
          <input type="text" name="label" value="<%= video.label || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Cover Image URL</label>
          <input type="text" name="cover_image" value="<%= video.cover_image || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Source URL</label>
          <input type="text" name="source_url" value="<%= video.source_url || '' %>" placeholder="https://..."
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Scraper</label>
          <select name="scraper_type"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
            <option value="">Default</option>
            <option value="dvd" <%= video.scraper_type === 'dvd' ? 'selected' : '' %>>DVD</option>
          </select>
        </div>
        <%- include('partials/video-tags', { tagType: 'genres', tagLabel: 'Genres', tagItems: genres, tagPlaceholder: 'Add genre...' }) %>
        <%- include('partials/video-tags', { tagType: 'cast', tagLabel: 'Cast', tagItems: cast, tagPlaceholder: 'Add cast member...' }) %>
      </div>
      <div class="mt-4 flex items-center gap-3">
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 px-4 py-1.5 rounded text-sm transition-colors">Save Changes</button>
        <span id="meta-save-status" class="text-sm"></span>
      </div>
    </form>
  </div>
</div>
<script src="/js/player.js"></script>
<%- include('partials/foot') %>
