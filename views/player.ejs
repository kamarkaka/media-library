<%- include('partials/head') %>
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<div class="flex flex-col flex-1">
  <!-- Video Player -->
  <div id="video-container" class="bg-black flex items-center justify-center relative"
       data-video-id="<%= video.id %>"
       data-resume-position="<%= playback ? playback.position : 0 %>"
       data-seek-step="<%= seekStep %>"
       data-direct-play="<%= canDirectPlay ? '1' : '' %>"
       data-stream-url="/api/videos/<%= video.id %>/stream"
       data-hls-url="/api/videos/<%= video.id %>/hls">
    <video id="video-player" class="w-full" style="max-width: 960px" playsinline></video>

    <% if (video.cover_image) { %>
    <div id="cover-overlay" class="absolute inset-0 flex items-center justify-center cursor-pointer transition-opacity duration-500 z-20" style="max-width: 960px; margin: 0 auto; left: 0; right: 0;">
      <img src="/api/videos/<%= video.id %>/cover" alt="" class="absolute inset-0 w-full h-full object-cover">
      <button id="cover-play-btn" class="relative z-10 w-16 h-16 bg-black/50 rounded-full flex items-center justify-center hover:bg-black/70 transition-colors">
        <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 20 20">
          <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/>
        </svg>
      </button>
    </div>
    <% } %>

    <!-- Quality Selector (top right) -->
    <div id="quality-wrapper" class="absolute top-3 right-3 z-10 select-none" style="max-width: 960px;">
      <button id="btn-quality" class="text-xs text-white/70 hover:text-white transition-colors px-2 py-0.5 bg-black/50 border border-white/20 rounded hidden">Auto</button>
      <div id="quality-menu" class="absolute top-full right-0 mt-1 bg-gray-900/95 border border-gray-700 rounded shadow-lg hidden min-w-[100px]"></div>
    </div>

    <!-- Bottom Controls -->
    <div id="player-controls" class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent px-4 pb-3 pt-8 z-10 opacity-0 transition-opacity duration-300 select-none" style="max-width: 960px; margin: 0 auto; left: 0; right: 0;">
      <div class="flex items-center gap-3">
        <!-- Play/Pause -->
        <button id="btn-play" class="text-white hover:text-blue-400 transition-colors flex-shrink-0">
          <svg id="icon-play" class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/></svg>
          <svg id="icon-pause" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M5.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75A.75.75 0 007.25 3h-1.5zM12.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75a.75.75 0 00-.75-.75h-1.5z"/></svg>
        </button>

        <!-- Seek Bar -->
        <div id="seek-bar" class="relative h-1 bg-gray-600 rounded cursor-pointer flex-1 group">
          <div id="seek-buffer" class="absolute h-full bg-gray-500 rounded"></div>
          <div id="seek-progress" class="absolute h-full bg-blue-500 rounded"></div>
          <div id="seek-handle" class="absolute top-1/2 -translate-y-1/2 w-3 h-3 bg-white rounded-full shadow opacity-0 group-hover:opacity-100 transition-opacity" style="left: 0"></div>
        </div>

        <!-- Time -->
        <span id="time-display" class="text-xs text-white/70 tabular-nums whitespace-nowrap flex-shrink-0">0:00 / 0:00</span>

        <!-- Fullscreen -->
        <button id="btn-fullscreen" class="text-white/80 hover:text-white transition-colors flex-shrink-0">
          <svg id="icon-fs-enter" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>
          <svg id="icon-fs-exit" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Prev/Next Navigation -->
  <div class="bg-gray-800 border-t border-gray-700/50 px-6 py-2 flex items-center justify-between">
    <% if (prevVideo) { %>
    <a href="/player/<%= prevVideo.id %>" class="flex items-center gap-1.5 text-sm text-gray-400 hover:text-white transition-colors" title="<%= prevVideo.filename %>">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"/></svg>
      <span class="truncate max-w-[200px]">Previous</span>
    </a>
    <% } else { %>
    <span></span>
    <% } %>
    <% if (nextVideo) { %>
    <a href="/player/<%= nextVideo.id %>" class="flex items-center gap-1.5 text-sm text-gray-400 hover:text-white transition-colors" title="<%= nextVideo.filename %>">
      <span class="truncate max-w-[200px]">Next</span>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"/></svg>
    </a>
    <% } else { %>
    <span></span>
    <% } %>
  </div>

  <!-- Video Details -->
  <div class="bg-gray-800 border-t border-gray-700/50 px-6 py-4 flex-shrink-0">
    <% const displayTitle = video.name || video.filename; %>
    <h1 class="text-base font-semibold break-words mb-4"><%= displayTitle %></h1>

    <div class="flex items-center justify-between mb-4">
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" id="matched-toggle" data-video-id="<%= video.id %>" <%= video.matched ? 'checked' : '' %> class="hidden">
        <div class="relative w-9 h-5">
          <div class="w-9 h-5 rounded-full transition-colors <%= video.matched ? 'bg-green-500' : 'bg-gray-600' %>" id="matched-track"></div>
          <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform <%= video.matched ? 'translate-x-4' : '' %>" id="matched-knob"></div>
        </div>
        <span class="text-sm text-gray-400">Matched</span>
      </label>
    </div>

    <div class="flex items-center justify-between mb-2">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Details</h2>
      <button type="button" id="details-edit-btn" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">Edit</button>
    </div>

    <!-- Read-only view -->
    <div id="details-view" class="text-sm text-gray-400 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-1 mb-2">
      <div class="flex justify-between"><span class="text-gray-500">Code</span><span class="text-gray-300 ml-2" data-view="code"><%= video.code || '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Name</span><span class="text-gray-300 truncate ml-2" data-view="name"><%= video.name || '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Release Date</span><span class="text-gray-300 ml-2" data-view="release_date" data-date="<%= video.release_date || '' %>"><%= video.release_date || '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Director</span><span class="text-gray-300 ml-2" data-view="director"><%= video.director || '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Maker</span><span class="text-gray-300 ml-2" data-view="maker"><%= video.maker || '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Label</span><span class="text-gray-300 ml-2" data-view="label"><%= video.label || '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Cover Image</span><span class="text-gray-300 truncate ml-2" data-view="cover_image"><% if (video.cover_image) { %><a href="<%= video.cover_image %>" target="_blank" class="text-blue-400 hover:text-blue-300 truncate block max-w-xs"><%= video.cover_image %></a><% } else { %>—<% } %></span></div>
      <div class="flex justify-between sm:col-span-2"><span class="text-gray-500">Genres</span><span class="text-gray-300 ml-2" data-view="genres"><% if (genres.length) { genres.forEach(function(g, i) { %><a href="/?genre=<%= encodeURIComponent(g.name) %>" class="text-blue-400 hover:text-blue-300"><%= g.name %></a><%= i < genres.length - 1 ? ', ' : '' %><% }); } else { %>—<% } %></span></div>
      <div class="flex justify-between sm:col-span-2"><span class="text-gray-500">Cast</span><span class="text-gray-300 ml-2" data-view="cast"><% if (cast.length) { cast.forEach(function(c, i) { %><a href="/?cast=<%= encodeURIComponent(c.name) %>" class="text-blue-400 hover:text-blue-300"><%= c.name %></a><%= i < cast.length - 1 ? ', ' : '' %><% }); } else { %>—<% } %></span></div>
    </div>

    <!-- Edit form (hidden by default) -->
    <form id="video-meta-form" data-video-id="<%= video.id %>" style="display: none">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-3 text-sm">
        <div>
          <label class="block text-gray-500 mb-1">Code</label>
          <input type="text" name="code" value="<%= video.code || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Name</label>
          <input type="text" name="name" value="<%= video.name || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Release Date</label>
          <input type="date" name="release_date" value="<%= video.release_date || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Director</label>
          <input type="text" name="director" value="<%= video.director || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Maker</label>
          <input type="text" name="maker" value="<%= video.maker || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Label</label>
          <input type="text" name="label" value="<%= video.label || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-gray-500 mb-1">Cover Image URL</label>
          <input type="text" name="cover_image" value="<%= video.cover_image || '' %>"
            class="w-full bg-gray-700 border border-gray-600 rounded px-2 py-1.5 text-white text-sm focus:outline-none focus:border-blue-500">
        </div>
        <%- include('partials/video-tags', { tagType: 'genres', tagLabel: 'Genres', tagItems: genres, tagPlaceholder: 'Add genre...' }) %>
        <%- include('partials/video-tags', { tagType: 'cast', tagLabel: 'Cast', tagItems: cast, tagPlaceholder: 'Add cast member...' }) %>
      </div>
      <div class="mt-4 flex items-center gap-3">
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 px-4 py-1.5 rounded text-sm transition-colors">Save Changes</button>
        <button type="button" onclick="showViewMode()" class="bg-gray-700 hover:bg-gray-600 px-4 py-1.5 rounded text-sm transition-colors">Cancel</button>
        <span id="meta-save-status" class="text-sm"></span>
      </div>
    </form>

    <%
      const GB = 1024 * 1024 * 1024;
      const MB = 1024 * 1024;
    %>
    <button type="button" id="metadata-toggle" class="flex items-center gap-1 text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 mt-4 pt-4 border-t border-gray-700/50 hover:text-gray-300 transition-colors">
      <svg id="metadata-chevron" class="w-3.5 h-3.5 transition-transform rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      Metadata
    </button>
    <div id="metadata-content" class="text-sm text-gray-400 grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-1 mb-4" style="display: grid">
      <div class="flex justify-between"><span class="text-gray-500">Filename</span><span class="text-gray-300 truncate ml-2"><%= video.filename %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Duration</span><span class="text-gray-300"><%= video.length != null ? Math.floor(video.length / 60) + 'm ' + (video.length % 60) + 's' : '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Resolution</span><span class="text-gray-300"><%= video.width && video.height ? video.width + ' × ' + video.height : '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Video Codec</span><span class="text-gray-300"><%= video.video_codec || '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Audio Codec</span><span class="text-gray-300"><%= video.audio_codec || '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Framerate</span><span class="text-gray-300"><%= video.framerate != null ? video.framerate + ' fps' : '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Bitrate</span><span class="text-gray-300"><%= video.bitrate ? (video.bitrate / 1000).toFixed(0) + ' kbps' : '—' %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">File Size</span><span class="text-gray-300"><%= video.file_size ? (video.file_size >= GB ? (video.file_size / GB).toFixed(2) + ' GB' : (video.file_size / MB).toFixed(1) + ' MB') : '—' %></span></div>
    </div>
  </div>
</div>
<script src="/js/player.js"></script>
<%- include('partials/foot') %>
