<%- include('partials/head') %>
<div class="max-w-6xl mx-auto p-4 sm:p-6">
  <h1 class="text-2xl font-bold mb-6">Favorite Moments</h1>

  <% if (!moments || moments.length === 0) { %>
  <p class="text-gray-500 text-sm">No saved moments yet. Open a video and click &ldquo;Save moment&rdquo;.</p>
  <% } else { %>
  <%
    function fmtTime(s) {
      s = Math.floor(s || 0);
      var h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
      var mm = (h > 0 && m < 10 ? '0' : '') + m;
      var ss = (sec < 10 ? '0' : '') + sec;
      return (h > 0 ? h + ':' : '') + mm + ':' + ss;
    }
  %>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
    <% moments.forEach(function (mo) { %>
    <div class="bg-gray-800 rounded-lg overflow-hidden relative" data-moment-id="<%= mo.id %>">
      <a href="/player/<%= mo.video_id %>?t=<%= mo.timestamp %><%= mo.file_id ? '&file=' + mo.file_id : '' %>" class="block hover:ring-2 hover:ring-blue-500 transition-all rounded-lg">
        <div class="aspect-video bg-gray-700 relative overflow-hidden">
          <img src="/api/moments/<%= mo.id %>/snapshot" alt="" class="w-full h-full object-cover" loading="lazy"
               onerror="this.onerror=null; this.src='/api/videos/<%= mo.video_id %>/cover'">
          <span class="absolute bottom-1 right-1 bg-black/70 text-white text-xs px-1.5 py-0.5 rounded tabular-nums"><%= fmtTime(mo.timestamp) %></span>
        </div>
        <div class="p-2">
          <p class="text-sm text-gray-200 break-words"><%= mo.name || mo.filename %></p>
        </div>
      </a>
      <button type="button" onclick="removeMoment('<%= mo.id %>')"
        class="absolute top-1 right-1 bg-black/60 hover:bg-red-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-xs transition-colors" title="Remove">&times;</button>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>
<script src="/js/moments.js"></script>
<%- include('partials/foot') %>
