<%- include('partials/head') %>
<div class="max-w-5xl mx-auto p-6">
  <h1 class="text-2xl font-bold mb-6">Browser Session</h1>

  <!-- Start form -->
  <div id="session-start" class="bg-gray-800 rounded-lg p-6 mb-6">
    <div class="flex gap-2">
      <input type="text" id="session-url" placeholder="Enter URL to navigate to..."
        class="flex-1 bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500">
      <input type="text" id="session-scraper" placeholder="Scraper type (optional)"
        class="w-48 bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500">
      <button id="session-start-btn" onclick="startBrowserSession()"
        class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded text-sm transition-colors whitespace-nowrap">Open</button>
    </div>
    <p id="session-error" class="text-red-400 text-sm mt-2 hidden"></p>
  </div>

  <!-- Browser viewer -->
  <div id="session-viewer" class="hidden">
    <div class="bg-gray-800 rounded-lg overflow-hidden mb-4">
      <div id="browser-container" class="relative cursor-crosshair" style="max-width: 1280px; margin: 0 auto;">
        <img id="browser-screenshot" class="w-full block" alt="Browser view"
          style="image-rendering: auto;">
        <div id="click-overlay" class="absolute inset-0"></div>
        <div id="loading-overlay" class="absolute inset-0 bg-black/50 flex items-center justify-center hidden">
          <svg class="w-8 h-8 text-white animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-3 mb-4">
      <input type="text" id="type-input" placeholder="Type text here and press Enter..."
        class="flex-1 bg-gray-700 border border-gray-600 rounded px-3 py-2 text-white text-sm focus:outline-none focus:border-blue-500">
      <button onclick="sendSpecialKey('Tab')" class="bg-gray-700 hover:bg-gray-600 px-3 py-2 rounded text-sm transition-colors">Tab</button>
      <button onclick="sendSpecialKey('Enter')" class="bg-gray-700 hover:bg-gray-600 px-3 py-2 rounded text-sm transition-colors">Enter</button>
      <button onclick="sendSpecialKey('Escape')" class="bg-gray-700 hover:bg-gray-600 px-3 py-2 rounded text-sm transition-colors">Esc</button>
    </div>

    <div class="flex items-center gap-3">
      <button onclick="saveBrowserSession()" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded text-sm transition-colors">Save Cookies & Close</button>
      <button onclick="closeBrowserSession()" class="bg-gray-700 hover:bg-gray-600 px-4 py-2 rounded text-sm transition-colors">Close Without Saving</button>
      <button onclick="refreshScreenshot()" class="bg-gray-700 hover:bg-gray-600 px-4 py-2 rounded text-sm transition-colors">Refresh</button>
      <span id="session-status" class="text-sm text-gray-400"></span>
    </div>
  </div>
</div>

<script>
(function () {
  var screenshot = document.getElementById('browser-screenshot');
  var overlay = document.getElementById('click-overlay');
  var loading = document.getElementById('loading-overlay');
  var startSection = document.getElementById('session-start');
  var viewer = document.getElementById('session-viewer');
  var typeInput = document.getElementById('type-input');
  var statusEl = document.getElementById('session-status');
  var errorEl = document.getElementById('session-error');
  var viewportWidth = 1280;
  var viewportHeight = 800;
  var busy = false;

  function showLoading() { loading.classList.remove('hidden'); busy = true; }
  function hideLoading() { loading.classList.add('hidden'); busy = false; }

  function updateScreenshot(base64) {
    screenshot.src = 'data:image/png;base64,' + base64;
  }

  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }

  window.startBrowserSession = function () {
    var url = document.getElementById('session-url').value.trim();
    var scraperType = document.getElementById('session-scraper').value.trim() || 'default';
    if (!url) return;

    errorEl.classList.add('hidden');
    document.getElementById('session-start-btn').disabled = true;
    document.getElementById('session-start-btn').textContent = 'Loading...';

    fetch('/api/scraper/session/start', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url: url, scraperType: scraperType }),
    })
      .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
      .then(function (result) {
        if (!result.ok) throw new Error(result.data.error);
        viewportWidth = result.data.viewport.width;
        viewportHeight = result.data.viewport.height;
        updateScreenshot(result.data.screenshot);
        startSection.classList.add('hidden');
        viewer.classList.remove('hidden');
      })
      .catch(function (err) {
        showError(err.message);
      })
      .finally(function () {
        document.getElementById('session-start-btn').disabled = false;
        document.getElementById('session-start-btn').textContent = 'Open';
      });
  };

  // Click on the browser view
  overlay.addEventListener('click', function (e) {
    if (busy) return;
    var rect = overlay.getBoundingClientRect();
    var scaleX = viewportWidth / rect.width;
    var scaleY = viewportHeight / rect.height;
    var x = Math.round((e.clientX - rect.left) * scaleX);
    var y = Math.round((e.clientY - rect.top) * scaleY);

    showLoading();
    fetch('/api/scraper/session/click', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ x: x, y: y }),
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.screenshot) updateScreenshot(data.screenshot);
      })
      .catch(function () {})
      .finally(hideLoading);
  });

  // Type text
  typeInput.addEventListener('keydown', function (e) {
    if (e.key !== 'Enter' || busy) return;
    e.preventDefault();
    var text = typeInput.value;
    if (!text) return;

    showLoading();
    fetch('/api/scraper/session/type', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text: text }),
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.screenshot) updateScreenshot(data.screenshot);
        typeInput.value = '';
      })
      .catch(function () {})
      .finally(hideLoading);
  });

  window.sendSpecialKey = function (key) {
    if (busy) return;
    showLoading();
    fetch('/api/scraper/session/keypress', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key: key }),
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.screenshot) updateScreenshot(data.screenshot);
      })
      .catch(function () {})
      .finally(hideLoading);
  };

  window.refreshScreenshot = function () {
    if (busy) return;
    showLoading();
    fetch('/api/scraper/session/screenshot')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.screenshot) updateScreenshot(data.screenshot);
      })
      .catch(function () {})
      .finally(hideLoading);
  };

  window.saveBrowserSession = function () {
    showLoading();
    statusEl.textContent = 'Saving cookies...';
    fetch('/api/scraper/session/save', { method: 'POST' })
      .then(function (r) { return r.json(); })
      .then(function () {
        statusEl.textContent = 'Cookies saved!';
        statusEl.className = 'text-sm text-green-400';
        viewer.classList.add('hidden');
        startSection.classList.remove('hidden');
      })
      .catch(function (err) {
        statusEl.textContent = 'Failed: ' + err.message;
        statusEl.className = 'text-sm text-red-400';
      })
      .finally(hideLoading);
  };

  window.closeBrowserSession = function () {
    fetch('/api/scraper/session/close', { method: 'POST' })
      .then(function () {
        viewer.classList.add('hidden');
        startSection.classList.remove('hidden');
      })
      .catch(function () {});
  };
})();
</script>
<%- include('partials/foot') %>
